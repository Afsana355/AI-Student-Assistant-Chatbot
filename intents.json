{
  "intents": [
    {
      "tag": "greeting",
      "patterns": ["Hi", "Hello", "Hey", "Good Morning"],
      "responses": [
        "Hello Student!",
        "Hi there!",
        "Welcome to AI Student Assistant"
      ]
    },

    {
      "tag": "goodbye",
      "patterns": ["Bye", "See you", "Goodbye"],
      "responses": [
        "Goodbye!",
        "Have a nice day!",
        "See you again!"
      ]
    },

    {
      "tag": "course",
      "patterns": [
        "What courses are available?",
        "Available courses",
        "Course list"
      ],
      "responses": [
        "Available courses are CSE, EEE, BBA and English.",
        "Our university offers multiple programs including CSE and BBA."
      ]
    },

    {
      "tag": "admission",
      "patterns": [
